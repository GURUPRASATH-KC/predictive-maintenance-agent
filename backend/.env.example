# MongoDB Atlas connection string
# Example: mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
DATABASE_NAME=predictive_maintenance

# Optional. If set, the AI Maintenance Agent will use OpenAI to generate
# richer natural-language recommendations. If left empty, a rule-based
# fallback generator is used automatically, so the app works either way.
OPENAI_API_KEY=

# CORS - the frontend origin allowed to call this API
FRONTEND_ORIGIN=http://localhost:5173
